# ─── Server ───────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# ─── JWT ──────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_in_production

# ─── DynamoDB ─────────────────────────────
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=IoT_Monitor_Table
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ─── IoT Simulator ────────────────────────
MQTT_MODE=local              # local | aws
PUBLISH_INTERVAL_MS=5000
ACTIVE_DEVICES=20
ANOMALY_PROBABILITY=0.05
MQTT_TOPIC_PREFIX=dt/devices
IOT_ENDPOINT=                # AWS IoT Core endpoint (MQTT mode)
CERT_PATH=./certs/           # X.509 certificate directory
BACKEND_URL=http://localhost:3000
SIM_SYSTEM_EMAIL=system@iot.local
SIM_SYSTEM_PASSWORD=System123!
SIM_ADMIN_EMAIL=admin@iot.local
SIM_ADMIN_PASSWORD=Admin123!
DEVICE_BATCH_CONCURRENCY=10

# ─── IoT Ingest (AWS only) ────────────────
IOT_API_KEY=                 # API key for IoT Rule HTTP action

